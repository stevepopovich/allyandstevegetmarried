# Copy to .env for local Netlify dev (never commit .env)

GOOGLE_SHEET_ID=
# Prefer Base64 (one line; multiline JSON in .env is not supported by dotenv).
# From a JSON key file: node -e "const fs=require('fs');process.stdout.write(Buffer.from(fs.readFileSync('service-account.json')).toString('base64'))"
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
# Or a single-line JSON string (not multiple lines):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

INVITE_SHEET_NAME=Invites
INVITE_COLUMN=A
RSVP_SHEET_NAME=RSVPs

# Production: set explicit allowed site URL(s)
ALLOWED_ORIGINS=http://localhost:8888
